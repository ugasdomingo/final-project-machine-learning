# Por defecto la API usa SQLite (./app.db) si no se define esta variable.
# En Railway NO hace falta definirla a mano: al añadir el plugin de PostgreSQL
# y referenciarlo desde el servicio, Railway inyecta DATABASE_URL automáticamente
# (el prefijo postgres:// se normaliza solo en App/database.py).
# DATABASE_URL=postgresql+psycopg2://usuario:password@host:5432/nombre_db
DATABASE_URL=sqlite:///./app.db
